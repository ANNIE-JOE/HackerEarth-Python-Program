import sys
def solve():
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    n = int(input_data[0])
    singers = input_data[1:]
    counts = {}
    for s in singers:
        counts[s] = counts.get(s, 0) + 1
    max_songs = 0
    for count in counts.values():
        if count > max_songs:
            max_songs = count
    favorite_singers_count = 0
    for count in counts.values():
        if count == max_songs:
            favorite_singers_count += 1
    print(favorite_singers_count)
if __name__ == "__main__":
    solve()

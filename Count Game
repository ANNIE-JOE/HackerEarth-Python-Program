def solve():
    import sys
    input_data = sys.stdin.read().split()
    if not input_data: return
    n = int(input_data[0])
    a = list(map(int, input_data[1:]))
    MOD = 10**9 + 7
    basis = []
    for x in a:
        for b in basis:
            x = min(x, x ^ b)
        if x > 0:
            basis.append(x)
            basis.sort(reverse=True)
    rank = len(basis)
    print(pow(2, n - rank, MOD))

solve()
